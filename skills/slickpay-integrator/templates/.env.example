# SlickPay Configuration
# DO NOT COMMIT YOUR REAL KEYS TO GITHUB

# Choose between: https://devapi.slick-pay.com/api/v2 (Sandbox) or https://api.slick-pay.com/api/v2 (Prod)
SLICKPAY_API_URL="https://devapi.slick-pay.com/api/v2"

# Your Merchant Public Key (Starts with pub_...)
SLICKPAY_PUBLIC_KEY="pub_test_your_key_here"

# Webhook Secret for validating SATIM callbacks
SLICKPAY_WEBHOOK_SECRET="whsec_test_your_secret_here"
